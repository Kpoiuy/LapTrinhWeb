@model BookDB.Models.Book

@{
    ViewData["Title"] = "Chi tiết sách";
}

<div class="container mt-4">
    <h2>Chi tiết sách</h2>
    <hr />

    <div class="row">
        <div class="col-md-4">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid" alt="@Model.Title">
            }
            else
            {
                <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 400px;">
                    Không có ảnh
                </div>
            }
        </div>
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">Tên sách</dt>
                <dd class="col-sm-9">@Model.Title</dd>

                <dt class="col-sm-3">Tác giả</dt>
                <dd class="col-sm-9">@Model.Author</dd>

                <dt class="col-sm-3">Năm xuất bản</dt>
                <dd class="col-sm-9">@Model.Year</dd>

                <dt class="col-sm-3">Nhà xuất bản</dt>
                <dd class="col-sm-9">@Model.Publisher</dd>

                <dt class="col-sm-3">Danh mục</dt>
                <dd class="col-sm-9">
                    <a asp-controller="Books" asp-action="Index" asp-route-categoryId="@Model.CategoryId">
                        @Model.Category?.Name
                    </a>
                </dd>

                @if (Model.Price.HasValue)
                {
                    <dt class="col-sm-3">Giá</dt>
                    <dd class="col-sm-9">@Model.Price.Value.ToString("N0") VND</dd>
                }

                @if (Model.Rating.HasValue)
                {
                    <dt class="col-sm-3">Đánh giá</dt>
                    <dd class="col-sm-9">@Model.Rating.Value / 5 ⭐</dd>
                }
            </dl>

            <div class="btn-group" role="group">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Xóa</a>
                <form asp-controller="Cart" asp-action="AddToCart" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-success">Thêm vào giỏ</button>
                </form>
                <a asp-action="Order" asp-route-id="@Model.Id" class="btn btn-primary">Đặt hàng</a>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
    </div>
</div>
