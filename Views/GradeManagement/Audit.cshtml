@{
    ViewData["Title"] = "Kiểm tra điểm";
}

<div class="container mt-4">
    <h2>Giao diện kiểm tra điểm</h2>
    <hr />

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h4>Bản ghi kiểm tra</h4>
                </div>
                <div class="card-body">
                    <p>Đây là giao diện kiểm tra cho các bản ghi điểm.</p>
                    <p>Tại đây bạn có thể xem và kiểm tra tất cả các hoạt động liên quan đến điểm.</p>
                    
                    <div class="alert alert-info mt-3">
                        <strong>Lưu ý:</strong> Chức năng kiểm tra là placeholder để minh họa.
                    </div>

                    <div class="mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Quay lại quản lý điểm</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
