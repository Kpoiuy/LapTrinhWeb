@{
    ViewData["Title"] = "Quản lý điểm";
}

<div class="container mt-4">
    <h2>Quản lý điểm</h2>
    <hr />

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4>Hệ thống quản lý điểm</h4>
                </div>
                <div class="card-body">
                    <p>Chào mừng đến với giao diện quản lý điểm.</p>
                    <p>Phần này cho phép bạn quản lý và xem điểm học tập.</p>
                    
                    <div class="mt-4">
                        <a asp-action="Audit" class="btn btn-primary">Xem bản ghi kiểm tra</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
