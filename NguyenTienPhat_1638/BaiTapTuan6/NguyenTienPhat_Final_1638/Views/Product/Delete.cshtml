@model NguyenTienPhat_Final_1638.Models.Product

@{
    ViewData["Title"] = "Xác nhận Xóa";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-lg rounded-3">
                <div class="card-header bg-danger text-white text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i> CẢNH BÁO XÓA</h4>
                </div>
                <div class="card-body text-center p-5">
                    <h5 class="text-secondary mb-3">Bạn có chắc chắn muốn xóa sản phẩm này không?</h5>
                    <h2 class="text-dark fw-bold mb-4">"@Model.Name"</h2>

                    <form asp-action="DeleteConfirmed" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-secondary px-4 py-2">Hủy bỏ</a>
                            <button type="submit" class="btn btn-danger px-4 py-2 fw-bold">Vâng, Xóa ngay!</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>