@model NguyenTienPhat_Final_1638.Models.Category

@{
    ViewData["Title"] = "Xác nhận xóa";
}

<div class="card border-danger">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> CẢNH BÁO XÓA</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-danger">
            <strong>Bạn có chắc chắn muốn xóa danh mục này không?</strong>
        </div>

        <table class="table table-borderless">
            <tr>
                <th width="150">Tên danh mục:</th>
                <td><strong>"@Model.Name"</strong></td>
            </tr>
            <tr>
                <th>Số sản phẩm:</th>
                <td><span class="badge bg-warning">@(Model.Products?.Count ?? 0) sản phẩm</span></td>
            </tr>
        </table>

        @if (Model.Products?.Any() == true)
        {
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Lưu ý:</strong> Danh mục này đang có @Model.Products.Count sản phẩm nên hệ thống sẽ không cho phép xóa.
            </div>
        }

        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger" disabled="@(Model.Products?.Any() == true)">
                    <i class="bi bi-trash"></i> Vâng, xóa ngay!
                </button>
                <a href="@Url.Action("Index")" class="btn btn-success">
                    <i class="bi bi-arrow-left"></i> Hủy bỏ
                </a>
            </div>
        </form>
    </div>
</div>
