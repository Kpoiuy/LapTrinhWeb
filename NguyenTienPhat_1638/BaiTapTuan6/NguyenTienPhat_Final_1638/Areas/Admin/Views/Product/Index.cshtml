@model IEnumerable<NguyenTienPhat_Final_1638.Models.Product>

@{
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<div class="mb-4">
    <a href="@Url.Action("Add")" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Thêm sản phẩm mới
    </a>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-box-seam"></i> Danh sách sản phẩm</span>
        <span class="badge bg-primary">@Model.Count() sản phẩm</span>
    </div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Hình ảnh</th>
                            <th>Tên sản phẩm</th>
                            <th>Danh mục</th>
                            <th>Giá</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                    {
                                        <img src="@product.ImageUrl" alt="@product.Name" 
                                             style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;">
                                    }
                                    else
                                    {
                                        <div class="bg-secondary d-flex align-items-center justify-content-center" 
                                             style="width: 60px; height: 60px; border-radius: 8px;">
                                            <i class="bi bi-image text-white"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <strong>@product.Name</strong>
                                    <br>
                                    <small class="text-muted">@product.Description</small>
                                </td>
                                <td>
                                    <span class="badge bg-info">@product.Category?.Name</span>
                                </td>
                                <td>
                                    <strong class="text-danger">@product.Price.ToString("N0") đ</strong>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a href="@Url.Action("Edit", new { id = product.Id })" 
                                           class="btn btn-sm btn-outline-warning">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a href="@Url.Action("Delete", new { id = product.Id })" 
                                           class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox" style="font-size: 4rem; color: #cbd5e0;"></i>
                <p class="text-muted mt-3 mb-0">Chưa có sản phẩm nào</p>
                <a href="@Url.Action("Add")" class="btn btn-primary mt-3">
                    <i class="bi bi-plus-circle"></i> Thêm sản phẩm đầu tiên
                </a>
            </div>
        }
    </div>
</div>
