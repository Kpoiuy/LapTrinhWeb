@model NguyenTienPhat_Final_1638.Models.Product

@{
    ViewData["Title"] = "Chi tiết Sản phẩm";
}

<div class="container mt-4">
    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-5 bg-light d-flex align-items-center justify-content-center p-4">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm" alt="@Model.Name" style="max-height: 400px; object-fit: contain;">
                }
                else
                {
                    <div class="text-muted text-center py-5">
                        <i class="bi bi-image" style="font-size: 5rem;"></i>
                        <p>Không có hình ảnh</p>
                    </div>
                }
            </div>
            <div class="col-md-7">
                <div class="card-body p-5">
                    <span class="badge bg-info text-dark mb-2 fs-6">@Model.Category?.Name</span>
                    <h2 class="card-title text-primary fw-bold">@Model.Name</h2>
                    <h3 class="text-danger fw-bold my-3">@Model.Price.ToString("#,##0.00")$</h3>

                    <h5 class="fw-bold mt-4">Mô tả sản phẩm:</h5>
                    <p class="card-text text-secondary" style="line-height: 1.8;">
                        @Model.Description
                    </p>

                    <hr class="my-4">
                    <div class="d-flex gap-2 mt-4">
                        <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning px-4 fw-bold">Sửa sản phẩm</a>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Quay lại danh sách</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>