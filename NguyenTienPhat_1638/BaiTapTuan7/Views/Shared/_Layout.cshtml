<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ thống đăng ký học phần</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BaiTapTuan7.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>

    <header class="app-header">
        <div class="container">
            <nav class="navbar navbar-expand-lg app-navbar px-3 px-lg-4">
                <a class="navbar-brand app-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-dot"></span>
                    Đăng ký học phần
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Chuyển đổi điều hướng">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 mt-3 mt-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Courses" asp-action="Index">Học phần</a>
                        </li>
                        @if (User.IsInRole(RoleNames.Student))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Enroll" asp-action="MyCourses">Học phần của tôi</a>
                            </li>
                        }
                        @if (User.IsInRole(RoleNames.Admin))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">Quản trị</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AdminCourses" asp-action="Index">Quản lý học phần</a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex flex-column flex-lg-row gap-2 align-items-lg-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="user-pill">Đã đăng nhập: @User.Identity.Name</span>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light app-btn-sm">Đăng xuất</button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light app-btn-sm">Đăng nhập</a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-warning app-btn-sm">Đăng ký</a>
                        }
                    </div>
                </div>
            </nav>
        </div>
    </header>

    <div class="container app-content">
        @if (TempData["Success"] is string successMessage)
        {
            <div class="alert alert-success app-alert alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
            </div>
        }
        @if (TempData["Error"] is string errorMessage)
        {
            <div class="alert alert-danger app-alert alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
            </div>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
            <span>&copy; 2026 Hệ thống đăng ký học phần</span>
            <span>ASP.NET Core MVC | EF Core | Identity</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
