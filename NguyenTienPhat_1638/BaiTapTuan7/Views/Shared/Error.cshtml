@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi hệ thống";
}

<h1 class="text-danger">Đã xảy ra lỗi.</h1>
<h2 class="text-danger">Hệ thống gặp lỗi khi xử lý yêu cầu của bạn.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Chế độ phát triển</h3>
<p>
    Khi chuyển sang môi trường <strong>Development</strong>, hệ thống sẽ hiển thị chi tiết lỗi để dễ kiểm tra.
</p>
<p>
    <strong>Không nên bật Development trên môi trường triển khai thật.</strong>
    Điều này có thể làm lộ thông tin nhạy cảm từ exception cho người dùng cuối.
    Khi debug cục bộ, hãy đặt biến môi trường <strong>ASPNETCORE_ENVIRONMENT</strong> thành <strong>Development</strong>
    rồi khởi động lại ứng dụng.
</p>
