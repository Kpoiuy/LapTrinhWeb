@model Category
@{
    ViewData["Title"] = "Chi tiết Category";
}

<h3 class="mb-3">Chi tiết Category</h3>

<div class="card">
    <div class="card-body">
        <p><strong>ID:</strong> @Model.Id</p>
        <p><strong>Tên:</strong> @Model.Name</p>
        <p><strong>Số sách:</strong> @Model.Books.Count</p>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Sửa</a>
    <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Model.Id">Xóa</a>
    <a class="btn btn-secondary" asp-action="Index">Quay lại</a>
</div>
