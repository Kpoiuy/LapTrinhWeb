@model Category
@{
    ViewData["Title"] = "Xóa Category";
}

<h3 class="mb-3 text-danger">Xác nhận xóa Category</h3>

@if (TempData["Error"] is not null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card mb-3">
    <div class="card-body">
        <p><strong>ID:</strong> @Model.Id</p>
        <p><strong>Tên:</strong> @Model.Name</p>
        <p><strong>Số sách:</strong> @Model.Books.Count</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="d-flex gap-2">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button class="btn btn-danger" type="submit">Xóa</button>
    <a class="btn btn-secondary" asp-action="Index">Hủy</a>
</form>
