@model List<Category>
@{
    ViewData["Title"] = "Categories";
    var keyword = ViewBag.Keyword as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Quản lý Categories</h3>
    <a class="btn btn-primary" asp-action="Create">Thêm category</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-6">
        <input class="form-control" name="keyword" value="@keyword" placeholder="Từ khóa category..." />
    </div>
    <div class="col-md-6 d-flex gap-2">
        <button class="btn btn-success" type="submit">Search</button>
        <a class="btn btn-secondary" asp-action="Index">Reset</a>
    </div>
</form>

<table class="table table-bordered table-hover">
    <thead class="table-light">
    <tr>
        <th>ID</th>
        <th>Tên category</th>
        <th>Số sách</th>
        <th style="width:280px;">Thao tác</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var c in Model)
    {
        <tr>
            <td>@c.Id</td>
            <td>@c.Name</td>
            <td>@c.Books.Count</td>
            <td class="d-flex gap-1">
                <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@c.Id">Chi tiết</a>
                <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@c.Id">Sửa</a>
                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@c.Id">Xóa</a>
            </td>
        </tr>
    }
    </tbody>
</table>
