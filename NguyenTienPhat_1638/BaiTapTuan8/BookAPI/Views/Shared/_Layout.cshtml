<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BaiTapTuan8</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="BooksMvc" asp-action="Index">BaiTapTuan8</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-controller="BooksMvc" asp-action="Index">Books</a>
                <a class="nav-link" asp-controller="CategoriesMvc" asp-action="Index">Categories</a>
                <a class="nav-link" href="/swagger">Swagger</a>
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
