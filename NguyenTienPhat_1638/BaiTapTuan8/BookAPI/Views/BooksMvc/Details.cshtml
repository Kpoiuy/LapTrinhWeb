@model Book
@{
    ViewData["Title"] = "Chi tiết Book";
}

<h3 class="mb-3">Chi tiết Book</h3>

<div class="card">
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" class="img-fluid" />
                }
            </div>
            <div class="col-md-9">
                <p><strong>ID:</strong> @Model.Id</p>
                <p><strong>Tên sách:</strong> @Model.Title</p>
                <p><strong>Tác giả:</strong> @Model.Author</p>
                <p><strong>Năm:</strong> @Model.Year</p>
                <p><strong>Nhà xuất bản:</strong> @Model.Publisher</p>
                <p><strong>Category:</strong> @Model.Category?.Name</p>
                <p><strong>Giá:</strong> @Model.Price.ToString("N0")</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Sửa</a>
    <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Model.Id">Xóa</a>
    <a class="btn btn-secondary" asp-action="Index">Quay lại</a>
</div>
