@model Book
@{
    ViewData["Title"] = "Xóa Book";
}

<h3 class="mb-3 text-danger">Xác nhận xóa Book</h3>
<div class="alert alert-warning">
    Bạn có chắc muốn xóa sách <strong>@Model.Title</strong>?
</div>

<div class="card mb-3">
    <div class="card-body">
        <p><strong>ID:</strong> @Model.Id</p>
        <p><strong>Tác giả:</strong> @Model.Author</p>
        <p><strong>Category:</strong> @Model.Category?.Name</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="d-flex gap-2">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button class="btn btn-danger" type="submit">Xóa</button>
    <a class="btn btn-secondary" asp-action="Index">Hủy</a>
</form>
